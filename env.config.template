# env.config.template — Azure Container Apps secrets reference
# Copy to env.config.DO_NOT_SHARE for local development (never commit the real file)
# In production, all values are injected as Container App secrets

# Flask session signing key (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=your-secret-key-here

# Azure AD App Registration (from portal.azure.com > Entra ID > App registrations)
AZURE_OIDC_TENANT_ID=your-tenant-id
AZURE_OIDC_CLIENT_ID=your-client-id
AZURE_OIDC_CLIENT_SECRET=your-client-secret

# Application base URL (set to the Container App FQDN in production)
# Example: https://saml-metadata-parser.your-env.eastus.azurecontainerapps.io
APP_BASE_URL=https://localhost:8080
